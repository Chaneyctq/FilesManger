└── build-profile.json5         # 构建配置
```

## 2. ArkTS 核心语言规范

### 2.1 设计原则
ArkTS 采用**静态类型**和**名义化类型系统**，禁止运行时改变对象布局，强制编译时类型检查。

### 2.2 强制语言限制
```typescript
// ✅ 正确：强制静态类型
interface UserProfile {
  readonly id: string;
  name: string;
  age: number;
}

let user: UserProfile = {
  id: '123',
  name: 'Alice',
  age: 30
};

// ✅ 正确：使用枚举替代字符串常量
enum ThemeType {
  LIGHT = 'light',
  DARK = 'dark'
}

// ❌ 禁止：any/unknown类型
let config: any = {}; // 违反规范

// ❌ 禁止：对象扩展运算符
const newUser = { ...user }; // 违反规范

// ❌ 禁止：运行时改变对象布局
user.newProperty = 'value'; // 违反规范
```

### 2.3 命名约定
- **类、枚举、命名空间**: PascalCase
- **变量、方法、参数**: camelCase
- **常量、枚举值**: UPPER_CASE_WITH_UNDERSCORES
- **布尔变量**: 使用肯定含义（isReady 而非 isNotReady）

### 2.4 静态方法中的this引用（重要）

**错误代码**: `arkts-no-standalone-this`

```typescript
// ❌ 错误：在静态方法中使用this
export class DateUtil {
  static formatTime(seconds: number): string {
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    // 错误：静态方法中不能使用this
    return `${this.padNumber(hours)}:${this.padNumber(minutes)}`;
  }
  
  private static padNumber(num: number): string {
    return num < 10 ? `0${num}` : `${num}`;
  }
}

// ✅ 正确：使用类名调用静态方法
export class DateUtil {
  static formatTime(seconds: number): string {
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    // 正确：使用类名调用静态方法
    return `${DateUtil.padNumber(hours)}:${DateUtil.padNumber(minutes)}`;
  }
  
  private static padNumber(num: number): string {
    return num < 10 ? `0${num}` : `${num}`;
  }
}
```

**核心规则**：
- ❌ **禁止**：在静态方法（stand-alone functions）中使用`this`关键字
- ✅ **强制**：静态方法调用其他静态成员时，必须使用类名而非`this`
- ✅ **原因**：ArkTS的静态方法是独立函数，没有`this`上下文
- ✅ **适用范围**：所有工具类、服务类、管理类的静态方法

**常见场景**：
```typescript
// 工具类示例
export class StringUtil {
  static formatText(text: string): string {
    // ✅ 正确
    return StringUtil.capitalize(StringUtil.trim(text));
    // ❌ 错误
    // return this.capitalize(this.trim(text));
  }
  
  private static capitalize(str: string): string {
    return str.charAt(0).toUpperCase() + str.slice(1);
  }
  
  private static trim(str: string): string {
    return str.trim();
  }
}

// 统计工具类示例
export class StatisticsUtil {
  static getTodayStats(data: Transaction[]): Stats {
    // ✅ 正确：使用类名
    return StatisticsUtil.calculate(data, DateUtil.getTodayStart(), DateUtil.getTodayEnd());
    // ❌ 错误
    // return this.calculate(data, DateUtil.getTodayStart(), DateUtil.getTodayEnd());
  }
  
  private static calculate(data: Transaction[], start: number, end: number): Stats {
    // 计算逻辑
  }
}
```

