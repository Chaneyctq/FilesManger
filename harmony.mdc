### 10.1 编译错误
```typescript
// ❌ 错误：arkts-no-any-unknown
let config: any = {};
// ✅ 解决：使用具体类型
interface Config { theme: 'light' | 'dark'; }
let config: Config = { theme: 'light' };

// ❌ 错误：arkts-no-spread
const newObj = { ...oldObj };
// ✅ 解决：手动复制属性
const newObj: ObjType = {
  prop1: oldObj.prop1,
  prop2: oldObj.prop2
};

// ❌ 错误：arkts-no-standalone-this
export class DateUtil {
  static formatTime(seconds: number): string {
    return `${this.padNumber(seconds)}`; // 错误：静态方法中使用this
  }
  private static padNumber(num: number): string {
    return num < 10 ? `0${num}` : `${num}`;
  }
}
// ✅ 解决：使用类名调用静态方法
export class DateUtil {
  static formatTime(seconds: number): string {
    return `${DateUtil.padNumber(seconds)}`; // 正确：使用类名
  }
  private static padNumber(num: number): string {
    return num < 10 ? `0${num}` : `${num}`;
  }
}
```

### 10.2 性能问题
```typescript
// ❌ 问题：长列表使用ForEach
ForEach(this.items, (item) => { ListItem() })

// ✅ 解决：使用LazyForEach
LazyForEach(this.dataSource, (item) => { ListItem() })

