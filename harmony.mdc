## 5. 错误处理规范

### 5.1 异步错误处理
```typescript
import { BusinessError } from '@ohos.base';

// ✅ 强制：所有Promise必须包含错误处理
async navigateToPage(url: string): Promise<void> {
  try {
    await router.pushUrl({ url: url });
  } catch (err) {
    const businessError = err as BusinessError;
    console.error(`导航失败. Code: ${businessError.code}, Message: ${businessError.message}`);
    
    switch (businessError.code) {
      case 401: // Parameter error
        this.showErrorToast('页面参数错误');
        break;
      case 1012600001: // Task is busy
        this.showErrorToast('系统繁忙，请稍后重试');
        break;
      default:
        this.showErrorToast('导航失败，请重试');
        break;
    }
    throw businessError;
  }
}
```

### 5.2 同步错误处理
```typescript
// ✅ 正确：使用返回值表示业务逻辑结果
validateUser(user: User): ValidationResult {
  if (!user.name || user.name.trim() === '') {
    return { isValid: false, errorMessage: '用户名不能为空' };
  }
  return { isValid: true, errorMessage: '' };
}

// ✅ 正确：try-catch处理异常
try {
  const data = JSON.parse(jsonString);
  return this.processData(data);
} catch (error) {
  console.error('JSON解析失败:', error);
  throw new Error('数据格式不正确');
}
```

