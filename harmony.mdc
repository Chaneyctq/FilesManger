## 3. 状态管理规范

### 3.1 装饰器选择指南
```typescript
// @State: 组件内部状态
@Component
struct HomePage {
  @State private isLoading: boolean = false;
}

// @Prop: 父->子单向传递
@Component
struct UserCard {
  @Prop userName: string = '';
}

// @Link: 父<->子双向绑定
@Component
struct CustomInput {
  @Link inputValue: string;
}

// @Provide/@Consume: 跨层级状态共享
@Component
struct MainPage {
  @Provide('theme') theme: ThemeType = ThemeType.LIGHT;
}

@Component
struct DeepChild {
  @Consume('theme') theme: ThemeType;
}

// @Observed/@ObjectLink: 复杂对象监听
@Observed
class UserModel {
  name: string = '';
  age: number = 0;
}

@Component
struct UserEditor {
  @ObjectLink user: UserModel;
}
```

### 3.2 全局状态管理
```typescript
// AppStorage: 全局状态
AppStorage.SetOrCreate('isLoggedIn', false);

@Component
struct LoginPage {
  @StorageLink('isLoggedIn') isLoggedIn: boolean = false;
  @StorageProp('userSettings') settings: UserSettings = {};
}

// PersistentStorage: 持久化状态
PersistentStorage.PersistProp('userTheme', 'light');
```

