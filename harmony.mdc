### 4.3 资源管理
```typescript
@Component
struct ResourceAwareComponent {
  private timer: number = -1;
  
  aboutToAppear() {
    this.timer = setInterval(() => {
      this.updateData();
    }, 1000);
  }
  
  // ✅ 强制：清理资源
  aboutToDisappear() {
    if (this.timer !== -1) {
      clearInterval(this.timer);
      this.timer = -1;
    }
  }
}
