## 4. 性能优化规范

### 4.1 UI渲染优化（强制执行）
```typescript
// ✅ 强制：长列表使用LazyForEach
@Component
struct UserList {
  build() {
    List() {
      LazyForEach(this.userDataSource, (user: User) => {
        ListItem() {
          UserCard({ user: user })
        }
        .reuseId(`user_${user.id}`)
      }, (user: User) => user.id.toString())
    }
  }
}

// ✅ 强制：条件渲染避免不必要的组件
if (this.isVisible) {
  ExpensiveComponent()
}

// ✅ 推荐：无状态组件使用@Reusable
@Reusable
@Component
struct UserCard {
  @Prop user: User;
  
  build() {
    // 纯函数式组件
  }
}
```

### 4.2 高性能代码规则
```typescript
// ✅ 强制：优先使用const
const MAX_RETRY_COUNT: number = 3;

// ✅ 强制：缓存循环中的属性访问
const maxCount = MyClass.CONFIG.MAX_COUNT;
for (let i = 0; i < maxCount; i++) {
  // 循环体
}

// ✅ 强制：数值计算使用TypedArray
const numbers = new Float32Array(1000);

// ✅ 强制：耗时任务使用TaskPool
@Concurrent
function heavyComputation(data: number[]): number {
  // 计算逻辑
}

const task = new taskpool.Task(heavyComputation, data);
const result = await taskpool.execute(task);
