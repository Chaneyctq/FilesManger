```typescript
// ✅ 强制：使用清晰的命名和注释
class UserAuthenticationService {
  /**
   * 验证用户登录凭证
   * @param username - 用户名
   * @param password - 密码
   * @returns 验证结果，包含token和用户信息
   */
  async validateCredentials(username: string, password: string): Promise<AuthResult> {
    // 实现逻辑
  }
}

// ✅ 强制：复杂逻辑添加必要注释
private calculateScore(attempts: number, timeSpent: number): number {
  // 基础分数：1000分
  const BASE_SCORE = 1000;
  // 时间惩罚：每秒扣除5分
  const timePenalty = timeSpent * 5;
  // 尝试次数惩罚：每次额外尝试扣除50分
  const attemptPenalty = Math.max(0, attempts - 1) * 50;
  
  return Math.max(0, BASE_SCORE - timePenalty - attemptPenalty);
}
```

