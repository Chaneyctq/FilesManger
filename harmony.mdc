### 12.6 WebResourceResponse配置

#### 正确设置HTTP响应
```typescript
this.webController.onInterceptRequest((request: WebResourceRequest) => {
  // ...读取文件数据...
  
  const response = new WebResourceResponse();
  
  // ✅ 关键1：设置正确的MIME类型
  const mimeType = this.getMimeType(decodedFileName);
  response.setResponseMimeType(mimeType);
  
  // ✅ 关键2：设置编码（文本文件）
  if (mimeType.startsWith('text/') || mimeType === 'application/json') {
    response.setResponseEncoding('utf-8');
  }
  
  // ✅ 关键3：设置响应数据
  response.setResponseData(fileData.buffer);
  
  // ✅ 关键4：设置状态码
  response.setResponseCode(200);
  
  // ✅ 关键5：设置响应头（可选）
  response.setResponseHeader([
    { headerKey: 'Access-Control-Allow-Origin', headerValue: '*' },
    { headerKey: 'Cache-Control', headerValue: 'public, max-age=31536000' }
  ]);
  
  return response;
});

private getMimeType(fileName: string): string {
  const ext = fileName.substring(fileName.lastIndexOf('.') + 1).toLowerCase();
  const mimeMap: Record<string, string> = {
    'glb': 'model/gltf-binary',
    'gltf': 'model/gltf+json',
    'bin': 'application/octet-stream',
    'jpg': 'image/jpeg',
    'png': 'image/png',
    'js': 'application/javascript',
    'json': 'application/json'
  };
  return mimeMap[ext] || 'application/octet-stream';
}
```

**MIME类型对照表**：
- `.glb` → `model/gltf-binary`
- `.gltf` → `model/gltf+json`
- `.bin` → `application/octet-stream`
- `.jpg/jpeg` → `image/jpeg`
- `.png` → `image/png`
- `.js` → `application/javascript`

