### 11.7 组件通信模式

#### 父子组件数据流
```typescript
// 父组件：GamePlay
@Component
struct GamePlay {
  @State private puzzlePieces: PuzzlePieceObservable[] = [];
  
  build() {
    Column() {
      // ✅ 使用回调函数处理子组件事件
      PuzzleBoard({
        pieces: this.puzzlePieces,  // 向下传递数据
        onSlotDrop: (slotId: number, pieceId: number): void => {
          this.handleSlotDrop(slotId, pieceId);  // 向上传递事件
        },
        onSlotPositionsUpdate: (positions: Map<number, SlotPosition>): void => {
          this.boardSlotPositions = positions;  // 接收子组件计算结果
        }
      })
    }
  }
}

// 子组件：PuzzleBoard
@Component
struct PuzzleBoard {
  @Prop pieces: PuzzlePieceObservable[];
  onSlotDrop?: (slotId: number, pieceId: number) => void;
  onSlotPositionsUpdate?: (positions: Map<number, SlotPosition>) => void;
  
  private handleDrop(slotId: number, pieceId: number): void {
    // 通知父组件
    if (this.onSlotDrop) {
      this.onSlotDrop(slotId, pieceId);
    }
  }
}
```

**通信原则**：
- ✅ 数据向下流动：使用`@Prop`传递数据给子组件
- ✅ 事件向上传递：使用回调函数通知父组件
- ✅ 回调函数使用可选类型（`?:`），并在调用前检查
- ❌ 避免子组件直接修改`@Prop`数据
- ✅ 复杂状态使用`@Observed/@ObjectLink`实现深度监听

