// HTML端：提供清理函数
window.cleanupThreeJS = function() {
  // 释放Three.js资源
  if (renderer) {
    renderer.dispose();
  }
  if (scene) {
    scene.traverse((object) => {
      if (object.geometry) object.geometry.dispose();
      if (object.material) {
        if (Array.isArray(object.material)) {
          object.material.forEach(m => m.dispose());
        } else {
          object.material.dispose();
        }
      }
    });
  }
  console.log('🧹 [HTML] Three.js资源已清理');
};
```

### 12.9 常见错误排查清单

#### 模型加载失败诊断
```typescript
// 检查点1：URL协议是否正确
console.log('[诊断] 请求URL:', url);
// ✅ 应该是：https://local.resource/models/xxx.glb
// ❌ 不应该是：resource://rawfile/xxx 或 file:///xxx

// 检查点2：文件名编码是否正确
console.log('[诊断] 编码文件名:', encodedFileName);
console.log('[诊断] 解码文件名:', decodedFileName);
// ✅ 解码后应该是中文：呼吸机+3d+模型.glb

// 检查点3：文件是否存在
try {
  const fileData = getContext(this).resourceManager.getRawFileContentSync(resourcePath);
  console.log('[诊断] ✅ 文件存在，大小:', fileData.byteLength);
} catch (error) {
  console.error('[诊断] ❌ 文件不存在或路径错误:', resourcePath);
}

// 检查点4：MIME类型是否正确
console.log('[诊断] MIME类型:', this.getMimeType(decodedFileName));
// ✅ .glb文件应该是：model/gltf-binary

// 检查点5：HTML端是否收到数据
// 在HTML中添加详细的错误处理
loader.load(url, onLoad, onProgress, (error) => {
  console.error('❌ [HTML] 加载失败详情:', {
    url: url,
    errorMessage: error.message,
    errorType: error.constructor.name
  });
});
```

### 12.10 核心经验总结

#### ✅ Web组件集成必须遵循的原则
1. **协议选择**：使用自定义虚拟URL（如`https://local.resource/`），避免`resource://`和`file://`
2. **时序控制**：在`onPageEnd`回调后延迟调用JavaScript函数
3. **资源拦截**：使用`onInterceptRequest`统一处理资源加载
4. **文件名处理**：使用`decodeURIComponent`解码中文文件名
5. **MIME类型**：根据文件扩展名设置正确的MIME类型
6. **资源清理**：在`aboutToDisappear`中清理缓存和Web资源

#### ❌ 常见陷阱
1. **过早调用JavaScript**：在HTML加载完成前调用会失败
2. **忘记解码URL**：中文文件名未解码导致找不到文件
3. **MIME类型错误**：GLB文件使用错误的MIME类型导致解析失败
4. **内存泄漏**：大文件缓存未清理，多次进入页面导致内存溢出
5. **协议混用**：在HTML中同时使用多种URL协议导致混乱

#### 🎯 开发效率提升技巧
1. **分层日志**：使用统一前缀和emoji，快速定位问题发生在哪一层
2. **先验证再集成**：使用纯HTML文件验证Three.js逻辑，再集成到ArkTS
3. **渐进式调试**：先加载简单模型，成功后再换复杂模型
4. **模拟测试**：在Chrome中模拟URL拦截逻辑，提前发现问题
5. **错误兜底**：每个异步操作都添加详细的错误处理和日志

## 13. 跨组件数据同步实战（记账应用案例）

### 13.1 多页面数据同步挑战

#### 问题场景
在多Tab应用中（如记账应用），当在一个页面修改数据后，其他页面需要立即更新：
- **HomePage**: 添加收支记录
- **TransactionPage**: 显示交易列表
- **StatisticsPage**: 显示统计数据
- **问题**: 数据修改后，切换Tab时其他页面不更新

```typescript
// ❌ 问题代码：只在 aboutToAppear 加载数据
@Component
export default struct TransactionPage {
  @State private transactions: Transaction[] = [];
  
  aboutToAppear(): void {
    this.loadData();  // 只在组件首次创建时加载
  }
  
  // 问题：切换Tab时不会重新加载，看不到最新数据
}
```

### 13.2 解决方案：AppStorage + @StorageLink + @Watch

#### 核心思路
使用全局状态管理实现跨组件通信，通过刷新标记触发所有页面更新。

```typescript
// ✅ 步骤1：在主页面初始化全局刷新标记
@Entry
@Component
struct MainPage {
  async aboutToAppear(): Promise<void> {
    // 初始化全局数据刷新标记
    if (!AppStorage.has('dataRefreshFlag')) {
      AppStorage.setOrCreate<number>('dataRefreshFlag', 0);
      console.log('[MainPage] 创建 dataRefreshFlag');
    }
  }
}

// ✅ 步骤2：各页面监听刷新标记
@Component
export default struct HomePage {
  @StorageLink('dataRefreshFlag') @Watch('onDataRefresh') dataRefreshFlag: number = 0;
  @State private transactions: Transaction[] = [];
  
  // 当 dataRefreshFlag 变化时自动调用
  onDataRefresh(): void {
    console.log('[HomePage] 检测到数据刷新标记变化:', this.dataRefreshFlag);
    this.loadData();
  }
  
  aboutToAppear(): void {
    this.loadData();
  }
}

// ✅ 步骤3：数据变更时触发刷新（使用递增计数器）
@Component
export default struct HomePage {
  private async handleAddTransaction(transaction: Transaction): Promise<void> {
    // 1. 添加记录
    this.transactions = [...this.transactions, transaction];
    await PreferencesUtil.getInstance().saveTransactions(this.transactions);
    
    // 2. 触发全局刷新（递增计数器确保每次都不同）
    const currentFlag = AppStorage.get<number>('dataRefreshFlag') || 0;
    const newFlag = currentFlag + 1;
    console.log('[HomePage] 触发数据刷新:', currentFlag, '->', newFlag);
    AppStorage.set<number>('dataRefreshFlag', newFlag);
    
    // 3. 验证（调试用）
    const verifyFlag = AppStorage.get<number>('dataRefreshFlag');
    console.log('[HomePage] 验证刷新标记已更新为:', verifyFlag);
  }
}
```

### 13.3 关键技术点

#### 1. 为什么使用递增计数器而非时间戳？

```typescript
// ❌ 错误：使用 Date.now() 可能导致值相同
AppStorage.set<number>('dataRefreshFlag', Date.now());
// 问题：快速连续调用时，Date.now() 可能返回相同值
// 导致 @Watch 不触发

// ✅ 正确：使用递增计数器
const currentFlag = AppStorage.get<number>('dataRefreshFlag') || 0;
const newFlag = currentFlag + 1;  // 每次加1，确保一定不同
AppStorage.set<number>('dataRefreshFlag', newFlag);
```

#### 2. @Watch 装饰器的正确使用

```typescript
// ✅ 正确：@StorageLink 配合 @Watch
@StorageLink('dataRefreshFlag') @Watch('onDataRefresh') dataRefreshFlag: number = 0;

onDataRefresh(): void {
  // 当 dataRefreshFlag 变化时自动调用
  this.loadData();
}

// ❌ 错误：只用 @StorageLink，没有监听变化
@StorageLink('dataRefreshFlag') dataRefreshFlag: number = 0;
// 问题：值会更新，但不会主动触发数据加载
```

#### 3. 所有修改数据的地方都要触发刷新

```typescript
// ✅ 添加记录时触发刷新
private async handleAddTransaction(transaction: Transaction): Promise<void> {
  this.transactions = [...this.transactions, transaction];
  await PreferencesUtil.getInstance().saveTransactions(this.transactions);
  
  // 触发刷新
  const currentFlag = AppStorage.get<number>('dataRefreshFlag') || 0;
  AppStorage.set<number>('dataRefreshFlag', currentFlag + 1);
}

// ✅ 删除记录时也要触发刷新
private async handleDelete(id: string): Promise<void> {
  this.transactions = this.transactions.filter(t => t.id !== id);
  await PreferencesUtil.getInstance().saveTransactions(this.transactions);
  
  // 触发刷新
  const currentFlag = AppStorage.get<number>('dataRefreshFlag') || 0;
  AppStorage.set<number>('dataRefreshFlag', currentFlag + 1);
}
```

### 13.4 数据持久化与初始化时序

#### Preferences 初始化问题

**问题**: `EntryAbility.onCreate` 可能未被调用（热重载问题），导致 Preferences 未初始化。

```typescript
// ✅ 解决方案：双重初始化保障
// 1. EntryAbility 中初始化（正常流程）
export default class EntryAbility extends UIAbility {
  async onCreate(...): Promise<void> {
    await PreferencesUtil.getInstance().init(this.context);
  }
}

// 2. MainPage 中也初始化（兜底方案）
@Entry
@Component
struct MainPage {
  async aboutToAppear(): Promise<void> {
    const context = getContext(this).getApplicationContext();
    await PreferencesUtil.getInstance().init(context);
    // init() 内部有 Promise 缓存，多次调用不会重复初始化
  }
}
```

#### Preferences 工具类设计

```typescript
export class PreferencesUtil {
  private static instance: PreferencesUtil;
  private preferences: dataPreferences.Preferences | null = null;
  private initPromise: Promise<void> | null = null;  // 缓存 Promise
  
  // ✅ init() 支持多次调用，但只初始化一次
  async init(context: common.Context): Promise<void> {
    if (this.initPromise) {
      return this.initPromise;  // 返回已有的 Promise
    }
    this.initPromise = this.doInit(context);
    return this.initPromise;
  }
  
  // ✅ 所有数据操作前等待初始化
  async waitForInit(): Promise<void> {
    // 主动等待 initPromise 创建（最多5秒）
    let retryCount = 0;
    while (!this.initPromise && retryCount < 50) {
      await new Promise<void>((resolve) => setTimeout(resolve, 100));
      retryCount++;
    }
    
    if (!this.initPromise) {
      throw new Error('初始化超时');
    }
    
    await this.initPromise;
    
    if (!this.preferences) {
      throw new Error('Preferences对象未创建');
    }
  }
  
  // ✅ 数据操作自动等待初始化
  async loadTransactions(): Promise<Transaction[]> {
    await this.waitForInit();  // 确保已初始化
    const jsonStr = await this.preferences!.get('transactions', '[]') as string;
    return JSON.parse(jsonStr);
  }
}
```

